# PrimeOps Agentic OS — Environment Variables
# Copy to .env and fill in your values

# Database — SQLite for local dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./primeops.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/primeops

# Google Cloud
GCS_BUCKET=your-gcs-bucket-name
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# GCP Service Account — download the full JSON key from GCP Console and point here
# IAM → Service Accounts → your-service-account → Keys → Add Key → JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ADK — URL the agents use to call the FastAPI data endpoints
API_BASE_URL=http://127.0.0.1:8080

# App
DEBUG=true
